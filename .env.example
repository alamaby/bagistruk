# Flutter client — bundled into the app at build time via flutter_dotenv.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Google Sign-In client IDs from Google Cloud Console.
# GOOGLE_WEB_CLIENT_ID is the Web OAuth client ID used as the Android
# serverClientId and by Supabase Auth. Android OAuth clients still need package
# name com.alamaby.bagistruk plus debug/release SHA-1 fingerprints in Google
# Cloud Console; their Android client IDs are not bundled here.
# GOOGLE_IOS_CLIENT_ID is required when building/running on iOS.
GOOGLE_WEB_CLIENT_ID=YOUR-WEB-CLIENT-ID.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=YOUR-IOS-CLIENT-ID.apps.googleusercontent.com

# Supabase Auth email confirmation/password reset redirect.
# Add this exact URL to Supabase Dashboard -> Authentication -> URL
# Configuration -> Redirect URLs. The app registers this custom scheme on
# Android/iOS so email links return to BagiStruk instead of localhost.
AUTH_EMAIL_REDIRECT_TO=bagistruk://auth/callback

# Ads are disabled by default. Use AdMob production banner unit IDs before
# enabling in release builds; empty values fall back to Google test units.
ADS_ENABLED=false
ADMOB_ANDROID_BANNER_ID=
ADMOB_IOS_BANNER_ID=

# Edge Function secrets — set with `supabase secrets set KEY=value`,
# NEVER bundled into the client.
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Required before enabling Google Play Billing validation.
GOOGLE_PLAY_PACKAGE_NAME=com.alamaby.bagistruk
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional for the scheduled inactive-user cleanup Edge Function.
# Set these as Supabase secrets, not client env values.
RESEND_API_KEY=
INACTIVE_REMINDER_FROM="BagiStruk <noreply@example.com>"
APP_NAME=BagiStruk
APP_URL=
INACTIVE_CLEANUP_LIMIT=100
INACTIVE_CLEANUP_SECRET=
