# Flutter client — bundled into the app at build time via flutter_dotenv.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...

# Google Sign-In client IDs from Google Cloud Console.
# GOOGLE_WEB_CLIENT_ID is used as the OAuth server client ID for Supabase.
# GOOGLE_IOS_CLIENT_ID is required when building/running on iOS.
GOOGLE_WEB_CLIENT_ID=YOUR-WEB-CLIENT-ID.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=YOUR-IOS-CLIENT-ID.apps.googleusercontent.com

# Edge Function secrets — set with `supabase secrets set KEY=value`,
# NEVER bundled into the client.
GEMINI_API_KEY=
OPENROUTER_API_KEY=
